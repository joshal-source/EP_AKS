# Copy to values-local.yaml and edit (gitignored).
# Applied after values.yaml and before values-install.yaml from the install script.

replicaCount: 2

# Match ACR_NAME / IMAGE_NAME / IMAGE_TAG from .env (deploy.sh auto-creates/updates this file)
image:
  repository: epacr.azurecr.io/edgeprocessor
  tag: latest
  pullPolicy: IfNotPresent

resources:
  requests:
    cpu: 2000m
    memory: 2Gi
  limits:
    cpu: 4000m
    memory: 4Gi

# Rolling update: maxSurge 0 avoids a third pod (and Splunk ghost instance) during deploys
strategy:
  rollingUpdate:
    maxSurge: 0
    maxUnavailable: 1

# Persistent volume per pod (Azure Disk via default storage class — one PVC per replica)
persistence:
  enabled: true
  size: 10Gi
  # storageClassName: managed-csi

# service:
#   type: LoadBalancer
#   annotations:
#     service.beta.kubernetes.io/azure-load-balancer-internal: "true"

# splunk:
#   groupConfigMapKey: EP_CORP_DC_1
